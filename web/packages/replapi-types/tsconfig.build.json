{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"rootDir": "src",
		"outDir": "dist",
		"allowImportingTsExtensions": false
	},
	"include": ["src/index.ts", "src/generated/**/*.ts"],
	"exclude": ["src/**/*.test.ts", "src/testdata"]
}
